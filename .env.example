# Copy this file to .env and fill in real values before running docker compose.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=America/Chicago

POSTGRES_DB=campsite
POSTGRES_USER=campsite
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Leave EMAIL_HOST blank to just print emails to the console (docker compose logs).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=oakholm@example.com
